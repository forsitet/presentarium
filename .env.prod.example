# Presentarium — production .env template.
# Copy to .env on the host that runs docker-compose.prod.yml and fill in real
# values. Never commit the real .env; only .env.prod.example lives in git.
#
# Generate strong random secrets with:
#   openssl rand -base64 48   # JWT_SECRET
#   openssl rand -base64 24   # DB_PASSWORD, MINIO_ROOT_PASSWORD, S3_SECRET_ACCESS_KEY
#
# Env-var names here match backend/internal/config/config.go exactly.

# ─── GHCR image owner ─────────────────────────────────────────────────────
# The GitHub user/org whose container registry hosts the built images.
# docker-compose.prod.yml resolves images as
# ghcr.io/${GHCR_USER}/presentarium-{backend,frontend}:latest.
GHCR_USER=your-github-username

# ─── Database ─────────────────────────────────────────────────────────────
# DB_HOST is set to `postgres` by the compose file — no need to set it here.
DB_PORT=5432
DB_USER=presentarium
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM
DB_NAME=presentarium
DB_SSLMODE=disable            # intra-docker-network traffic; TLS lives at the edge

# ─── Server ───────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# ─── JWT ──────────────────────────────────────────────────────────────────
# MUST be a long random secret. Rotating this invalidates every active session.
JWT_SECRET=CHANGE_ME_AT_LEAST_48_RANDOM_BYTES
JWT_ACCESS_TOKEN_TTL_MIN=15   # minutes
JWT_REFRESH_TOKEN_TTL_DAYS=7  # days

# ─── Public URLs / CORS ───────────────────────────────────────────────────
# The origin your users hit in the browser. Used for CORS allow-list AND for
# absolute links in password-reset emails.
CORS_ALLOWED_ORIGIN=https://your-domain.example
APP_BASE_URL=https://your-domain.example

# ─── File uploads ─────────────────────────────────────────────────────────
UPLOADS_DIR=/app/uploads      # matches the `uploads:` named volume in compose

# ─── Object storage (MinIO on the docker network) ─────────────────────────
# Superuser — only used by the minio-init one-shot container.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Scoped service account used by the backend for all S3 calls.
S3_ACCESS_KEY_ID=presentarium-prod
S3_SECRET_ACCESS_KEY=CHANGE_ME_STRONG_RANDOM
S3_BUCKET_PUBLIC=presentarium-public     # anonymous-read bucket for slide/question images
S3_BUCKET_PRIVATE=presentarium-private   # presigned-read only — source .pptx files
S3_REGION=us-east-1                      # any value works for MinIO
S3_FORCE_PATH_STYLE=true                 # required for MinIO/R2

# S3_ENDPOINT and S3_PUBLIC_BASE_URL are set in docker-compose.prod.yml —
# do NOT override them here. The compose file wires:
#   S3_ENDPOINT        = http://minio:9000
#   S3_PUBLIC_BASE_URL = /media/${S3_BUCKET_PUBLIC}
# so backend-issued image URLs flow through the nginx /media/ proxy.

# ─── Migrations ───────────────────────────────────────────────────────────
MIGRATIONS_PATH=migrations

# ─── SMTP (password-reset emails; optional — leave blank to disable) ──────
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_USER=noreply@your-domain.example
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@your-domain.example
