# Database
DB_HOST=postgres           # PostgreSQL host
DB_PORT=5432               # PostgreSQL port
DB_USER=presentarium       # Database user
DB_PASSWORD=secret         # Database password
DB_NAME=presentarium       # Database name
DB_SSLMODE=disable         # SSL mode (disable for local dev)

# Server
SERVER_PORT=8080           # HTTP server port
SERVER_HOST=0.0.0.0        # HTTP server bind address

# JWT
JWT_SECRET=change-me-in-production  # Secret key for JWT signing
JWT_ACCESS_TTL=15m          # Access token TTL
JWT_REFRESH_TTL=168h        # Refresh token TTL (7 days)

# Frontend
FRONTEND_URL=http://localhost:5173  # Frontend URL for CORS

# File uploads
UPLOADS_DIR=./uploads       # Directory for uploaded files
MAX_UPLOAD_SIZE=5242880     # Max upload size in bytes (5 MB)

# Migrations
MIGRATIONS_PATH=migrations  # Path to SQL migration files

# SMTP (for password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=noreply@example.com
