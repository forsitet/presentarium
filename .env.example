# Database
DB_HOST=postgres           # PostgreSQL host
DB_PORT=5432               # PostgreSQL port
DB_USER=presentarium       # Database user
DB_PASSWORD=secret         # Database password
DB_NAME=presentarium       # Database name
DB_SSLMODE=disable         # SSL mode (disable for local dev)

# Server
SERVER_PORT=8080           # HTTP server port
SERVER_HOST=0.0.0.0        # HTTP server bind address

# JWT
JWT_SECRET=change-me-in-production  # Secret key for JWT signing
JWT_ACCESS_TTL=15m          # Access token TTL
JWT_REFRESH_TTL=168h        # Refresh token TTL (7 days)

# Frontend
FRONTEND_URL=http://localhost:5173  # Frontend URL for CORS

# File uploads
UPLOADS_DIR=./uploads       # Directory for uploaded files
MAX_UPLOAD_SIZE=5242880     # Max upload size in bytes (5 MB)

# Object storage (MinIO in dev/prod; S3-compatible API also accepts R2/AWS/Yandex)
# Two roles:
#   MINIO_ROOT_*        — superuser for the MinIO container (mc admin only)
#   S3_ACCESS_KEY_ID/*  — scoped service account used by the backend
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-dev-only
S3_ACCESS_KEY_ID=presentarium
S3_SECRET_ACCESS_KEY=presentarium-dev-secret
S3_BUCKET_PUBLIC=presentarium-public      # Anonymous read; slide images, question images
S3_BUCKET_PRIVATE=presentarium-private    # Presigned read only; source .pptx, exports
S3_REGION=us-east-1                       # Any value works for MinIO
S3_FORCE_PATH_STYLE=true                  # Required for MinIO/R2; false for native AWS S3
# Where the backend calls MinIO from. If you run the backend INSIDE docker-compose,
# the compose file overrides this to http://minio:9000. If you run the backend
# directly on the host (go run ./cmd/server), leave it as localhost.
S3_ENDPOINT=http://localhost:9000
# Public URL served to browsers/participants. In dev we expose MinIO on localhost;
# in prod this is the cdn.* domain fronted by nginx.
S3_PUBLIC_BASE_URL=http://localhost:9000/presentarium-public

# Migrations
MIGRATIONS_PATH=migrations  # Path to SQL migration files

# SMTP (for password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=noreply@example.com
